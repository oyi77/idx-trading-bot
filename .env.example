# ============================================================
# IDX AI TRADING BOT — Environment Configuration
# ============================================================
# Copy this to .env and fill in your actual keys
# NEVER commit .env to git. NEVER share keys in chat.
# ============================================================

# --- Bot Identity ---
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=youridxbot

# --- Data Feeds ---
ITICK_API_KEY=your_itick_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
MASSIVE_API_KEY=your_massive_api_key_here

# --- AI / LLM (via OpenRouter) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=gpt-4o-mini
MAX_ANALYSIS_TOKENS=4096

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/trading_bot.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/idx_bot

# --- Payment (Midtrans) ---
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_MERCHANT_ID=your_merchant_id_here
MIDTRANS_IS_PRODUCTION=false

# --- Broker Integration (optional) ---
STOCKBIT_API_KEY=your_stockbit_api_key_here
AJAIB_API_KEY=your_ajaib_api_key_here

# --- App Config ---
DEBUG=true
LOG_LEVEL=INFO
WEBHOOK_URL=https://your-domain.com/webhook
PORT=8080
